{
    "id": "org.kde.keepsecret",
    "branch": "master",
    "runtime": "org.kde.Platform",
    "runtime-version": "6.11",
    "sdk": "org.kde.Sdk",
    "command": "keepsecret",
    "tags": [
        "nightly"
    ],
    "desktop-file-name-suffix": " (Nightly)",
    "finish-args": [
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--device=dri",
        "--talk-name=org.freedesktop.secrets"
    ],
    "cleanup": [
        "/share/qlogging-categories6"
    ],
    "modules": [
        {    
            "name": "kirigami-app-components",
            "buildsystem": "cmake-ninja",
            "config-opts": [
                "-DBUILD_TESTING=OFF",
                "-DBUILD_WITH_QT6=ON"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://invent.kde.org/libraries/kirigami-app-components"
                }
            ]
        },
        {
            "name": "keepsecret",
            "buildsystem": "cmake-ninja",
            "config-opts": [
                "-DBUILD_TESTING=OFF"
            ],
            "sources": [
                {
                    "type": "dir",
                    "path": "."
                }
            ]
        }
    ]
}
